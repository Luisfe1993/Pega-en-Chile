# --- LLM providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# GitHub Models (free tier with rate limits). Get a fine-grained PAT at
# https://github.com/settings/personal-access-tokens — enable the "Models"
# read permission under Account permissions.
# Model IDs use a vendor prefix, e.g. openai/gpt-4.1-mini, openai/gpt-4.1,
# anthropic/claude-sonnet-4, meta/llama-3.3-70b-instruct.
GITHUB_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4.1-mini

# Optional: route cheap calls to a local model via Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# --- Job board credentials (optional, used by adapters) ---
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
GETONBOARD_TOKEN=

# --- Enrichment ---
NEWSAPI_KEY=

# --- Storage ---
PEGA_DB_PATH=./data/pega.sqlite

# --- Behavior ---
PEGA_HUMAN_IN_THE_LOOP=true   # do not change to false; the graph enforces it
PEGA_DEFAULT_LOCALE=es-CL
